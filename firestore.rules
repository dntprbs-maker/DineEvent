rules_version = '2';

/**
 * ============================================================
 *  DineEvent - Firestore 보안 규칙 (Firebase Auth 기반)
 *  작성일: 2026-07-08
 *
 *  인증 체계:
 *    - 관리자 권한은 admins/{uid} 문서로 판별
 *      { role: 'super' }                          → 마스터 관리자
 *      { role: 'tenant', tenantId: '가맹점ID' }   → 해당 가맹점 관리자
 *    - 손님(비로그인)은 공개 읽기 + 응모 생성 + 룰렛 재고 차감만 가능
 *
 *  TODO (실 서비스 전):
 *    1) 룰렛 재고 차감(content/prizes 공개 쓰기)을 Cloud Function으로 이전
 *    2) entries 공개 create에 필드 검증(키 목록/타입) 추가
 * ============================================================
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // ── 전역 헬퍼 함수 ──────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function adminData() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
    }
    function isSuperAdmin() {
      return isAdmin() && adminData().role == 'super';
    }
    function isTenantAdmin(tenantId) {
      return isAdmin()
        && (adminData().role == 'super'
            || (adminData().role == 'tenant' && adminData().tenantId == tenantId));
    }

    // ── 관리자 권한 매핑 ────────────────────────────────────────
    // 본인 문서 읽기 허용(로그인 직후 역할 확인용), 발급/회수는 슈퍼관리자만
    match /admins/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow write: if isSuperAdmin();
    }

    // ── 테넌트 루트 문서 (status, brandName 등) ─────────────────
    // 고객 페이지가 매장 상태를 확인해야 하므로 read 공개
    match /tenants/{tenantId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ── 테넌트별 하위 컬렉션 ────────────────────────────────────
    // 매장 기본정보: read 공개 (QR 홈/위치 페이지), write 관리자
    match /tenants/{tenantId}/settings/{docId} {
      allow read: if true;
      allow write: if isTenantAdmin(tenantId);
    }

    // 공지사항: read 공개 (이벤트 페이지 공지 목록), write 관리자
    match /tenants/{tenantId}/notices/{docId} {
      allow read: if true;
      allow write: if isTenantAdmin(tenantId);
    }

    // 메뉴: read 공개, write 관리자
    match /tenants/{tenantId}/menus/{docId} {
      allow read: if true;
      allow write: if isTenantAdmin(tenantId);
    }

    // 콘텐츠(경품 목록/메뉴 이미지): read 공개
    // ⚠️ 손님 룰렛이 클라이언트에서 직접 재고를 차감하므로 write도 공개
    //    (TODO 1 — Cloud Function 이전 전까지 임시 허용)
    match /tenants/{tenantId}/content/{docId} {
      allow read, write: if true;
    }

    // 응모 로그(개인정보 포함): 생성은 손님 누구나, 조회/삭제는 관리자만
    match /tenants/{tenantId}/entries/{docId} {
      allow create: if true;
      allow read, update, delete: if isTenantAdmin(tenantId);
    }

    // 공지 템플릿: 관리자 전용
    match /tenants/{tenantId}/noticeTemplates/{docId} {
      allow read, write: if isTenantAdmin(tenantId);
    }

    // ── 전역 컬렉션 ─────────────────────────────────────────────
    // SMS 템플릿: 관리자(아무 매장이나) 전용
    match /smsTemplates/{docId} {
      allow read, write: if isAdmin();
    }

    // ── 레거시 루트 경로 (단일 매장 시절 폴백) ──────────────────
    // fetchDocWithFallback이 테넌트 경로에 문서가 없으면 루트를 조회함
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 그 외 모든 경로: 기본 차단
  }
}
